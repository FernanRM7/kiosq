{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "apps/front/dist"
      }
    },
    {
      "src": "apps/back/dist/main.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "apps/back/dist/main.js" },
    { "src": "/(.*)", "dest": "apps/front/dist/$1" },
    { "src": "/", "dest": "apps/front/dist/index.html" }
  ]
}
