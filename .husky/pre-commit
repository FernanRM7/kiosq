#!/usr/bin/env sh
# Validate that the current branch follows the allowed prefixes:
# feat, fix, docs, chore, refactor

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)

if [ -z "$BRANCH" ]; then
  echo "husky - pre-commit: unable to determine current branch."
  exit 1
fi

case "$BRANCH" in
  feat|feat/*|feat-*|fix|fix/*|fix-*|docs|docs/*|docs-*|chore|chore/*|chore-*|refactor|refactor/*|refactor-*)
    ;;
  *)
    echo "husky - pre-commit: branch '$BRANCH' is not allowed."
    echo "  Branch name must be or start with: feat, fix, docs, chore, refactor"
    exit 1
    ;;
esac

# Exit on any error
set -e

# Check if there are any staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED_FILES" ]; then
  echo "No staged files to format"
  exit 0
fi

# Run formatter
npx ultracite fix
FORMAT_EXIT_CODE=$?

# Re-stage files that were already staged
echo "$STAGED_FILES" | while IFS= read -r file; do
  if [ -f "$file" ]; then
    git add -- "$file"
  fi
done

if [ $FORMAT_EXIT_CODE -ne 0 ]; then
  echo "Ultracite found issues that could not be auto-fixed."
  exit $FORMAT_EXIT_CODE
fi

echo "✨ Files formatted by Ultracite"
