{
  "name": "kiosq",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "build": "npm run build:vercel",
    "build:vercel": "npm run build:back && cp apps/back/dist/main.js api/index.js && npm run build:front",
    "build:back": "npm --prefix apps/back run build",
    "build:front": "npm --prefix apps/front run build",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "turbo": "^2.9.16",
    "ultracite": "^7.8.2"
  },
  "packageManager": "npm@11.10.0"
}
