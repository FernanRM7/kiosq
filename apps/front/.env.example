# ─── Frontend (apps/front) ────────────────────────────────────────────────────

# URL base del backend NestJS.
# En desarrollo local apunta al servidor de Nest (puerto por defecto: 3000).
# En producción reemplazar con la URL pública del backend (ej. https://api.kiosq.app).
# Compatibilidad Tauri: en el entorno desktop se inyecta la URL del servidor local.
VITE_API_URL=http://localhost:3000

# Slug del tenant para el login con PIN (login/pin).
# Cada kiosko físico se instala con el slug de su workspace.
# El dependiente ingresa código + PIN, backend autentica contra este tenant.
# VITE_KIOSK_TENANT_SLUG=local-1
