{
  "name": "back",
  "version": "0.0.1",
  "private": true,
  "description": "",
  "license": "UNLICENSED",
  "author": "",
  "main": "dist/main.js",
  "scripts": {
    "postinstall": "prisma generate",
    "build": "prisma generate && nest build && node ./scripts/copy-prisma-engine.cjs",
    "start": "node dist/main",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "format": "oxfmt",
    "lint": "oxlint",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:cov": "jest --config jest.config.cjs --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --config jest.config.cjs --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.5",
    "@prisma/client": "^6.19.3",
    "@workos-inc/node": "^10.2.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.2.0",
    "jose": "^6.2.3",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "redis": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.27",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "dotenv": "^16.4.7",
    "esbuild": "^0.25.0",
    "esbuild-loader": "^4.2.2",
    "jest": "^30.0.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "prisma": "^6.19.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "ultracite": "^7.8.2",
    "webpack-node-externals": "^3.0.0"
  },
  "jest": {
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "moduleNameMapper": {
      "^jose$": "<rootDir>/__mocks__/jose.cjs",
      "^jose/(.*)$": "<rootDir>/__mocks__/jose.cjs"
    },
    "rootDir": "src",
    "testEnvironment": "node",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!(jose)/)"
    ]
  },
  "prisma": {
    "seed": "bun run prisma/seed.ts"
  }
}
