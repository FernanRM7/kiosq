{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "builds": [
    {
      "src": "dist/main.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "dist/libquery_engine-rhel-openssl-3.0.x.so.node"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/main.js"
    }
  ],
  "env": {
    "PRISMA_QUERY_ENGINE_BINARY": "/var/task/apps/back/dist/libquery_engine-rhel-openssl-3.0.x.so.node"
  }
}
