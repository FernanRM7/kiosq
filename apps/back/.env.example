# Supabase PostgreSQL
# DATABASE_URL: connection pooler, recomendado para la app.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Entorno de ejecución
# development → logs con pino-pretty (legibles en terminal)
# production  → logs JSON crudos (optimizados para agregadores)
NODE_ENV=development

# Nivel de verbosidad de los logs (fatal, error, warn, info, debug, trace)
# Por defecto: info
LOG_LEVEL=info

# DIRECT_URL: conexión directa, recomendada para migraciones de Prisma.
# Si una prueba inyecta solo DATABASE_URL o solo DIRECT_URL en el proceso,
# Prisma fijará ambas conexiones a ese valor para no mezclar una BD local y una remota.
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# WorkOS AuthKit
# Obtener en: https://dashboard.workos.com/api-keys
WORKOS_API_KEY=sk_...

# Obtener en: https://dashboard.workos.com/configuration
WORKOS_CLIENT_ID=client_...

# Mínimo 32 caracteres. Generar con: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=

# URI registrada en el dashboard de WorkOS → Redirects → Redirect URIs.
# Debe coincidir EXACTAMENTE con el valor configurado en WorkOS.
WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# URL base del frontend — a dónde redirige el backend tras la autenticación.
APP_URL=http://localhost:5173

# Orígenes permitidos para CORS (separados por comas)
CORS_ORIGIN=http://localhost:5173,http://localhost:1420
# Redis
REDIS_HOST=
REDIS_PORT=

# WorkOS Webhooks
# Obtener en: https://dashboard.workos.com/webhooks → Signing secret
# Configurar la URL del endpoint como: https://tu-dominio.com/webhooks/workos
WORKOS_WEBHOOK_SECRET=whsec_...

# Tolerancia de clock skew para verificación de firma de webhooks (ms).
# Por defecto 300000 (5 min). Aumentar si el serverless tiene drift de reloj.
# WORKOS_WEBHOOK_TOLERANCE_MS=300000

# URL a donde WorkOS redirige tras completar el logout server-side.
# DEBE estar registrada como Redirect URI en el dashboard de AuthKit.
# Si no se configura, usa el valor de APP_URL.
# WORKOS_LOGOUT_RETURN_TO=http://localhost:5173/login
